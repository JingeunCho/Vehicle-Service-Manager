<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Phase 20: 차량 제원 정규화 마이그레이션
        - vehicle: is_primary 컬럼 추가, oil_interval/last_oil_change_date 제거
        - 신규 테이블: wheel_spec, tire_spec, vehicle_spec, maintenance_record
    -->

    <!-- 1) vehicle 테이블 정리 -->
    <changeSet id="1.0.1-1" author="antigravity">
        <!--
            is_primary는 changelog-1.0.0.xml의 vehicle 테이블 생성 시 이미 포함되어 있으므로 추가하지 않음.
            기존 oil_interval, last_oil_change_date 컬럼을 제거.
            소모품 이력은 maintenance_record 테이블로 관리 (changeSet 1.0.1-5).
        -->
        <dropColumn tableName="vehicle" columnName="oil_interval"/>
        <dropColumn tableName="vehicle" columnName="last_oil_change_date"/>
    </changeSet>

    <!-- 2) wheel_spec 테이블 생성 -->
    <changeSet id="1.0.1-2" author="antigravity">
        <createTable tableName="wheel_spec">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="vehicle_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_wheel_spec_vehicle"
                             referencedTableName="vehicle" referencedColumnNames="id"/>
            </column>
            <column name="brand" type="VARCHAR(100)"/>
            <column name="model" type="VARCHAR(100)"/>
            <!-- 직경 (inch, 예: 17, 18) -->
            <column name="diameter" type="INT"/>
            <!-- 림폭 (J 단위, 예: 8.5) -->
            <column name="width" type="FLOAT"/>
            <!-- 옵셋 (예: +35, -5) -->
            <column name="wheel_offset" type="INT"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- 3) tire_spec 테이블 생성 -->
    <changeSet id="1.0.1-3" author="antigravity">
        <createTable tableName="tire_spec">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="vehicle_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_tire_spec_vehicle"
                             referencedTableName="vehicle" referencedColumnNames="id"/>
            </column>
            <column name="brand" type="VARCHAR(100)"/>
            <column name="model" type="VARCHAR(100)"/>
            <!-- 단면폭 (mm, 예: 225/45/17 에서 225) -->
            <column name="width" type="INT"/>
            <!-- 편평비 (%, 예: 225/45/17 에서 45) -->
            <column name="aspect_ratio" type="INT"/>
            <!-- 인치 (예: 225/45/17 에서 17) -->
            <column name="diameter" type="INT"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- 4) vehicle_spec 테이블 생성 (WheelSpec/TireSpec을 FK로 참조) -->
    <changeSet id="1.0.1-4" author="antigravity">
        <createTable tableName="vehicle_spec">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <!-- 1:1 관계 -->
            <column name="vehicle_id" type="BIGINT">
                <constraints nullable="false" unique="true"
                             foreignKeyName="fk_vehicle_spec_vehicle"
                             referencedTableName="vehicle" referencedColumnNames="id"/>
            </column>
            <!-- 구동 방식: FF, FR, MR, RR, AWD -->
            <column name="drive_type" type="VARCHAR(10)"/>
            <!-- 현재 장착 중인 전륜 휠 (최신 wheel_spec row 참조) -->
            <column name="front_wheel_id" type="BIGINT">
                <constraints foreignKeyName="fk_vehicle_spec_front_wheel"
                             referencedTableName="wheel_spec" referencedColumnNames="id"/>
            </column>
            <!-- 현재 장착 중인 후륜 휠 -->
            <column name="rear_wheel_id" type="BIGINT">
                <constraints foreignKeyName="fk_vehicle_spec_rear_wheel"
                             referencedTableName="wheel_spec" referencedColumnNames="id"/>
            </column>
            <!-- 현재 장착 중인 전륜 타이어 -->
            <column name="front_tire_id" type="BIGINT">
                <constraints foreignKeyName="fk_vehicle_spec_front_tire"
                             referencedTableName="tire_spec" referencedColumnNames="id"/>
            </column>
            <!-- 현재 장착 중인 후륜 타이어 -->
            <column name="rear_tire_id" type="BIGINT">
                <constraints foreignKeyName="fk_vehicle_spec_rear_tire"
                             referencedTableName="tire_spec" referencedColumnNames="id"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- 5) ledger 테이블에 maintenance_type 컬럼 추가 -->
    <!-- maintenance_record 별도 테이블 대신 ledger에 nullable 컬럼으로 통합 -->
    <!-- 오일 교환/브레이크 교체 등 차계부 기록 시 maintenanceType을 함께 입력하면 -->
    <!-- 차량 조회 시 소모품별 최신 교환 이력 자동 계산 가능 -->
    <changeSet id="1.0.1-5" author="antigravity">
        <addColumn tableName="ledger">
            <column name="maintenance_type" type="VARCHAR(50)">
                <!-- nullable: 일반 차계부는 null, 소모품 교환 기록은 Enum값 -->
            </column>
        </addColumn>
    </changeSet>

    <!-- 6) Category 엔터티 → Enum 리팩토링 -->
    <changeSet id="1.0.1-6" author="antigravity">
        <!-- 기존 category_id 외래키 및 컬럼 제거 -->
        <dropForeignKeyConstraint baseTableName="ledger" constraintName="fk_ledger_category"/>
        <dropColumn tableName="ledger" columnName="category_id"/>
        
        <!-- 새로운 Enum 기반 category 및 title 컬럼 추가 -->
        <addColumn tableName="ledger">
            <column name="category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        
        <!-- 더 이상 필요 없는 category 테이블 삭제 -->
        <dropTable tableName="category"/>
    </changeSet>

</databaseChangeLog>
